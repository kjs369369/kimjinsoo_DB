# Anthropic Claude API key — for program description/tag auto-suggestion
# Get one at https://console.anthropic.com/
# 로컬 개발: 이 파일을 복사해서 .env.local 로 저장 후 실제 키 입력
# Vercel 배포: 대시보드 → Settings → Environment Variables 에 추가
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# /vault 페이지 잠금 해제용 비밀번호
# 설정하지 않으면 기본값 "1234" 가 사용됩니다 (개발용, 배포 전 반드시 변경)
VAULT_PASSWORD=your-strong-secret

# Google Apps Script 웹앱 URL — 관리자 페이지 + 데이터 동기화
# 1. Google Sheets 새 파일 생성
# 2. 확장 프로그램 → Apps Script → gas/Code.gs 코드 붙여넣기
# 3. 배포 → 웹 앱 (실행: 나, 액세스: 모든 사용자)
# 4. 배포 URL을 아래에 입력
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/xxxxxxxx/exec
